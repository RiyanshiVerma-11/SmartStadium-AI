# 🔑 SmartStadium AI Environment Configuration
# Copy this file to .env and fill in your keys

# Google Gemini API Key (Get at: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Model name (flash is recommended for speed/cost)
# GEMINI_MODEL=gemini-2.0-flash

# Google Maps API Key for venue navigation, heatmaps, and embed views
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: Google Identity Services client ID
GOOGLE_IDENTITY_CLIENT_ID=your_google_identity_client_id_here

# Environment mode
ENV=development
