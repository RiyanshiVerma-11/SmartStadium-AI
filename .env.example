# 🔑 SmartStadium AI Environment Configuration
# Copy this file to .env and fill in your keys

# Google Gemini API Key (Get at: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Model name (flash is recommended for speed/cost)
# GEMINI_MODEL=gemini-2.0-flash

# Google Maps API Key for venue navigation, heatmaps, and embed views
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: Google Identity Services client ID
GOOGLE_IDENTITY_CLIENT_ID=your_google_identity_client_id_here

# Optional: Google Cloud Translation API key (for live multilingual emergency alerts)
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Optional: Google Cloud Text-to-Speech API key for live stadium PA announcements.
# Leave unset to use the free browser speech fallback instead.
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# Optional: voice override for English announcements
# GOOGLE_TTS_VOICE_NAME=en-US-Neural2-C

# Environment mode
ENV=development
